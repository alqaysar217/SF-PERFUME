
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Fragrance or watch product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "displayOrder": { "type": "number", "description": "Manual display order/priority" },
        "image": { "type": "string" },
        "size": { "type": "string" },
        "category": { "type": "string", "enum": ["men", "women", "watches"] },
        "description": { "type": "string" },
        "ingredients": { "type": "string" },
        "projection": { "type": "string" },
        "longevity": { "type": "string" },
        "isOffer": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "brand", "price", "category"]
    },
    "Brand": {
      "title": "Brand",
      "description": "Global brands list",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logo": { "type": "string" }
      },
      "required": ["name"]
    },
    "BankAccount": {
      "title": "Bank Account",
      "description": "Local bank account details for transfers",
      "type": "object",
      "properties": {
        "bank": { "type": "string" },
        "name": { "type": "string" },
        "account": { "type": "string" },
        "type": { "type": "string", "enum": ["bank", "exchange", "wallet"] }
      },
      "required": ["bank", "name", "account"]
    },
    "FAQ": {
      "title": "FAQ",
      "description": "Frequently asked questions",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" }
      },
      "required": ["question", "answer"]
    },
    "Review": {
      "title": "Customer Review",
      "description": "Testimonials from customers",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "content", "rating"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Home page slider banners",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "image"]
    },
    "TrashItem": {
      "title": "Trash Item",
      "description": "Temporarily deleted items",
      "type": "object",
      "properties": {
        "originalData": { "type": "object" },
        "originalCollection": { "type": "string" },
        "deletedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "#/backend/entities/Product",
      "description": "Collection of all products"
    },
    "/brands/{brandId}": {
      "schema": "#/backend/entities/Brand",
      "description": "Global luxury brands"
    },
    "/accounts/{accountId}": {
      "schema": "#/backend/entities/BankAccount",
      "description": "Payment bank accounts"
    },
    "/faqs/{faqId}": {
      "schema": "#/backend/entities/FAQ",
      "description": "Frequently asked questions list"
    },
    "/reviews/{reviewId}": {
      "schema": "#/backend/entities/Review",
      "description": "Customer testimonials"
    },
    "/banners/{bannerId}": {
      "schema": "#/backend/entities/Banner",
      "description": "Home page promotional banners"
    },
    "/trash/{trashId}": {
      "schema": "#/backend/entities/TrashItem",
      "description": "Deleted items for recovery"
    }
  }
}
