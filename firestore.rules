rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // وظيفة للتحقق مما إذا كان المستخدم مسجل الدخول (المدير)
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    // القواعد العامة للمنتجات والخدمات
    match /products/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /brands/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /accounts/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /faqs/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /reviews/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /banners/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // سلة المحذوفات: للمدير الموثق فقط
    match /trash/{id} {
      allow read, write: if isAuthenticated();
    }
  }
}